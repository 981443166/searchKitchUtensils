<h1 class="text-3xl font-bold mb-6">创建分类</h1>
<div class="bg-white rounded-lg shadow-md p-6">
  <form action="/admin/categories" method="POST">
    <div class="mb-4">
      <label for="name" class="block text-gray-700 mb-2">名称</label>
      <input type="text" id="name" name="name" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
    </div>
    <div class="mt-6">
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">创建</button>
      <a href="/admin/categories" class="ml-4 text-gray-600 hover:text-gray-800">取消</a>
    </div>
  </form>
</div>