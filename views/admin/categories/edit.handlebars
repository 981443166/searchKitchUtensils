<h1 class="text-3xl font-bold mb-6">编辑分类</h1>
<div class="bg-white rounded-lg shadow-md p-6">
  <form action="/admin/categories/{{category.id}}" method="POST">
    <input type="hidden" name="_method" value="PUT">
    <div class="mb-4">
      <label for="name" class="block text-gray-700 mb-2">名称</label>
      <input type="text" id="name" name="name" value="{{category.name}}" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
    </div>
    <div class="mt-6">
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">保存</button>
      <a href="/admin/categories" class="ml-4 text-gray-600 hover:text-gray-800">取消</a>
    </div>
  </form>
</div>