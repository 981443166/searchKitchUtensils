<h1 class="text-3xl font-bold mb-6">修改密码</h1>

<div class="max-w-md mx-auto bg-white rounded-lg shadow-md p-6">
  {{#if error}}
  <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
    {{error}}
  </div>
  {{/if}}

  {{#if success}}
  <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
    {{success}}
  </div>
  {{/if}}

  <form action="/admin/change-password" method="POST">
    <div class="mb-4">
      <label for="currentPassword" class="block text-gray-700 font-medium mb-2">当前密码</label>
      <input type="password" id="currentPassword" name="currentPassword" required
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div class="mb-4">
      <label for="newPassword" class="block text-gray-700 font-medium mb-2">新密码</label>
      <input type="password" id="newPassword" name="newPassword" required minlength="6"
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
      <p class="text-sm text-gray-500 mt-1">密码长度至少为6位</p>
    </div>

    <div class="mb-6">
      <label for="confirmPassword" class="block text-gray-700 font-medium mb-2">确认新密码</label>
      <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6"
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
    </div>

    <div class="flex items-center justify-between">
      <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
        修改密码
      </button>
      <a href="/admin" class="text-gray-600 hover:text-gray-800">
        返回后台
      </a>
    </div>
  </form>
</div>
