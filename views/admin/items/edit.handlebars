<h1 class="text-3xl font-bold mb-6">编辑物品</h1>
<div class="bg-white rounded-lg shadow-md p-6">
  <form action="/admin/items/{{item.id}}" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_method" value="PUT">
    <div class="mb-4">
      <label for="name" class="block text-gray-700 mb-2">名称</label>
      <input type="text" id="name" name="name" value="{{item.name}}" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
    </div>
    <div class="mb-4">
      <label for="description" class="block text-gray-700 mb-2">描述</label>
      <textarea id="description" name="description" rows="3" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">{{item.description}}</textarea>
    </div>
    <div class="mb-4">
      <label for="specifications" class="block text-gray-700 mb-2">规格参数</label>
      <textarea id="specifications" name="specifications" rows="2" placeholder="例如：材质：不锈钢；尺寸：30cm；重量：500g" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">{{item.specifications}}</textarea>
      <p class="text-gray-500 text-sm mt-1">简要填写关键规格参数，如材质、尺寸、重量等</p>
    </div>
    <div class="mb-4">
      <label for="price" class="block text-gray-700 mb-2">价格</label>
      <input type="number" id="price" name="price" step="0.01" value="{{item.price}}" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
    </div>
    <div class="mb-4">
      <label for="category_id" class="block text-gray-700 mb-2">分类</label>
      <select id="category_id" name="category_id" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        {{#each categories}}
        <option value="{{id}}" {{#if (eq ../item.category_id id)}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="mb-4">
      <label for="image" class="block text-gray-700 mb-2">图片</label>
      {{#if item.image_path}}
      <div class="mb-2">
        <img src="{{item.image_path}}" alt="{{item.name}}" class="w-32 h-32 object-cover rounded-md">
        <p class="text-gray-500 text-sm mt-1">当前图片：{{item.image_name}}</p>
      </div>
      {{/if}}
      <input type="file" id="image" name="image" accept="image/jpeg,image/jpg,image/png,image/gif,image/webp" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
      <p class="text-gray-500 text-sm mt-1">支持格式：JPG、PNG、GIF、WEBP，最大5MB（不上传则保留原图片）</p>
    </div>
    <div class="mt-6">
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">保存</button>
      <a href="/admin/items" class="ml-4 text-gray-600 hover:text-gray-800">取消</a>
    </div>
  </form>
</div>