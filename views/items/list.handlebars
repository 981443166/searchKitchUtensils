<h1 class="text-3xl font-bold mb-6">所有厨具</h1>
<div class="mb-4 flex flex-col sm:flex-row sm:justify-between sm:items-center">
  <form action="/items" method="GET" class="mb-2 sm:mb-0">
    <div class="flex items-center">
      <label for="sort" class="block text-sm font-medium text-gray-700 mr-2">排序方式：</label>
      <select id="sort" name="sort" class="w-full sm:w-auto px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="default" {{#if (eq sort 'default')}}selected{{/if}}>默认排序</option>
        <option value="price_asc" {{#if (eq sort 'price_asc')}}selected{{/if}}>价格从低到高</option>
        <option value="price_desc" {{#if (eq sort 'price_desc')}}selected{{/if}}>价格从高到低</option>
      </select>
      <button type="submit" class="ml-2 bg-blue-600 text-white px-3 py-2 rounded-md hover:bg-blue-700">排序</button>
    </div>
  </form>
</div>
<div id="items-container" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  {{#each items}}
  <a href="/items/{{id}}" class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-shadow block cursor-pointer">
    {{#if image_path}}
    <div class="mb-3">
      <img src="{{image_path}}" alt="{{name}}" class="w-full h-48 object-cover rounded-md">
    </div>
    {{else}}
    <div class="mb-3">
      <div class="w-full h-48 bg-gray-200 rounded-md flex items-center justify-center">
        <span class="text-gray-400 text-sm">暂无图片</span>
      </div>
    </div>
    {{/if}}
    <h2 class="text-lg font-semibold mb-2">{{name}}</h2>
    <p class="text-gray-600 text-sm mb-2">{{category_name}}</p>
    {{#if specifications}}
    <p class="text-gray-500 text-xs mb-2 line-clamp-2">{{specifications}}</p>
    {{/if}}
    <p class="text-gray-800 font-bold mb-2">¥{{price}}</p>
  </a>
  {{/each}}
</div>